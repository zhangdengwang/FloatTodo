<Window x:Class="FloatTodo.App.MiniWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FloatTodo Mini"
        Width="120"
        Height="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        Closing="MiniWidgetWindow_Closing">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="任务">
                <MenuItem Header="新增任务..."
                          Click="OpenQuickAddTaskWindow_Click"/>
                <MenuItem Header="查看未完成任务"
                          Click="OnPlaceholderMenuItemClick"/>
                <MenuItem Header="查看快截止任务"
                          Click="OnPlaceholderMenuItemClick"/>
            </MenuItem>
            <MenuItem Header="AI 拆解">
                <MenuItem Header="新建项目拆解..."
                          Click="OnPlaceholderMenuItemClick"/>
                <MenuItem Header="查看候选任务"
                          Click="OnPlaceholderMenuItemClick"/>
            </MenuItem>
            <MenuItem Header="日常记录">
                <MenuItem Header="喝水 +1"
                          Click="DrinkWaterMenuItem_Click"/>
                <MenuItem Header="休息眼睛 +1"
                          Click="RestEyesMenuItem_Click"/>
                <MenuItem Header="起身活动 +1"
                          Click="StandUpMenuItem_Click"/>
                <MenuItem Header="新增记录项..."
                          Click="OnPlaceholderMenuItemClick"/>
            </MenuItem>
            <MenuItem Header="项目进度">
                <MenuItem Header="查看项目进度"
                          Click="OnPlaceholderMenuItemClick"/>
            </MenuItem>
            <MenuItem Header="设置">
                <MenuItem Header="API Key 设置..."
                          Click="OnPlaceholderMenuItemClick"/>
                <MenuItem Header="关于 FloatTodo"
                          Click="OnPlaceholderMenuItemClick"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="打开完整面板"
                      Click="ToggleMainWindowMenuItem_Click"/>
            <MenuItem Header="退出"
                      Click="ExitMenuItem_Click"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Grid>
        <Border Background="#22FFFFFF"
                CornerRadius="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="120"
                Height="120">
            <Grid>
                <TextBlock Text="FT"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <Image Source="pack://application:,,,/Assets/Pet/pet_has_task.png"
                       Width="100"
                       Height="100"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
