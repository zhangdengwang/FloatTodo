<Window x:Class="FloatTodo.App.MiniWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FloatTodo Mini Debug"
        Width="100"
        Height="100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="显示/隐藏主面板"
                      Click="ToggleMainWindowMenuItem_Click"/>
            <Separator/>
            <MenuItem Header="退出"
                      Click="ExitMenuItem_Click"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Grid>
        <Border Background="#1AFFFFFF"
                BorderBrush="#40FFFFFF"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Image Source="Assets/Pet/pet_has_task.png"
                       Width="86"
                       Height="86"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       ImageFailed="WidgetImage_ImageFailed"/>
                <TextBlock x:Name="FallbackText"
                           Text="FT"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#FF333333"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
