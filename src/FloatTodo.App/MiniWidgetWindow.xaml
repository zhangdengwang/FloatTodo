<Window x:Class="FloatTodo.App.MiniWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FloatTodo Mini Debug"
        Width="160"
        Height="160"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="LightYellow"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        Closing="MiniWidgetWindow_Closing">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="显示/隐藏主面板"
                      Click="ToggleMainWindowMenuItem_Click"/>
            <Separator/>
            <MenuItem Header="退出"
                      Click="ExitMenuItem_Click"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Grid>
        <TextBlock Text="FT"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="Black"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <Image Source="pack://application:,,,/Assets/Pet/pet_has_task.png"
               Width="100"
               Height="100"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
    </Grid>
</Window>
