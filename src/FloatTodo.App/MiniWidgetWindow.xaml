<Window x:Class="FloatTodo.App.MiniWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FloatTodo Mini"
        Width="120"
        Height="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        Closing="MiniWidgetWindow_Closing">
    <Window.ContextMenu>
        <ContextMenu Opened="ContextMenu_Opened">
            <MenuItem Header="任务">
                <MenuItem Header="新增任务..."
                          Click="OpenQuickAddTaskWindow_Click"/>
                <MenuItem Header="查看未完成任务"
                          Click="OpenUnfinishedTasks_Click"/>
                <MenuItem Header="查看快截止任务"
                          Click="OpenDueSoonTasks_Click"/>
            </MenuItem>
            <MenuItem Header="AI 拆解">
                <MenuItem Header="新建项目拆解..."
                          Click="OpenAiBreakdown_Click"/>
                <MenuItem Header="查看候选任务"
                          Click="ViewAiCandidates_Click"/>
            </MenuItem>
            <MenuItem Header="日常记录">
                <MenuItem x:Name="DrinkWaterMenuItem"
                          Header="喝水 +1（次数：0，上次：未记录，阈值：60分钟）"
                          Click="DrinkWaterMenuItem_Click"/>
                <MenuItem x:Name="RestEyesMenuItem"
                          Header="休息眼睛 +1（次数：0，上次：未记录，阈值：45分钟）"
                          Click="RestEyesMenuItem_Click"/>
                <MenuItem x:Name="StandUpMenuItem"
                          Header="起身活动 +1（次数：0，上次：未记录，阈值：90分钟）"
                          Click="StandUpMenuItem_Click"/>
                <MenuItem Header="查看日常记录..."
                          Click="OpenDailyRecords_Click"/>
                <MenuItem Header="新增记录项..."
                          Click="OpenAddDailyRecord_Click"/>
            </MenuItem>
            <MenuItem Header="项目进度">
                <MenuItem Header="查看项目进度"
                          Click="OpenProjectProgress_Click"/>
            </MenuItem>
            <MenuItem Header="设置">
                <MenuItem Header="API Key 设置..."
                          Click="OnPlaceholderMenuItemClick"/>
                <MenuItem Header="关于 FloatTodo"
                          Click="OnPlaceholderMenuItemClick"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="打开完整面板"
                      Click="ToggleMainWindowMenuItem_Click"/>
            <MenuItem Header="退出"
                      Click="ExitMenuItem_Click"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Grid>
        <Border Background="#22FFFFFF"
                CornerRadius="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="120"
                Height="120">
            <Grid>
                <TextBlock Text="FT"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <Image x:Name="PetImage"
                       Source="pack://application:,,,/Assets/Pet/pet_has_task.png"
                       Width="100"
                       Height="100"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                <!-- Badge in top-right -->
                <Border x:Name="BadgeRoot"
                        Background="#D92D2D"
                        Width="32"
                        Height="20"
                        CornerRadius="10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,4,4,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="BadgeText"
                               Text="1"
                               Foreground="White"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="11"/>
                </Border>

                <Border x:Name="ReminderRoot"
                        Background="#DDFFFFFF"
                        BorderBrush="#66000000"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="7,3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="2"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ReminderText"
                               Text="请喝水"
                               Foreground="#222"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="104"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
