<Window x:Class="FloatTodo.App.QuickAddSubTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增小任务"
        Width="390"
        Height="430"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="76"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="94"/>
            <RowDefinition Height="38"/>
            <RowDefinition Height="38"/>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="任务标题"
                   VerticalAlignment="Center"/>
        <TextBox x:Name="TitleTextBox"
                 Grid.Column="1"
                 Margin="0,4"
                 VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="1"
                   Text="详细内容"
                   VerticalAlignment="Top"
                   Margin="0,8,0,0"/>
        <TextBox x:Name="DescriptionTextBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="0,4"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

        <TextBlock Grid.Row="2"
                   Text="优先级"
                   VerticalAlignment="Center"/>
        <ComboBox x:Name="PriorityComboBox"
                  Grid.Row="2"
                  Grid.Column="1"
                  Margin="0,4"
                  SelectedIndex="0">
            <ComboBoxItem Content="普通"/>
            <ComboBoxItem Content="重要"/>
            <ComboBoxItem Content="紧急"/>
        </ComboBox>

        <TextBlock Grid.Row="3"
                   Text="截止日期"
                   VerticalAlignment="Center"/>
        <DatePicker x:Name="DueDatePicker"
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="0,4"/>

        <TextBlock Grid.Row="4"
                   Text="截止时间"
                   VerticalAlignment="Center"/>
        <StackPanel Grid.Row="4"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Margin="0,4">
            <ComboBox x:Name="DueHourComboBox"
                      Width="72"/>
            <TextBlock Text="时"
                       VerticalAlignment="Center"
                       Margin="6,0,10,0"/>
            <ComboBox x:Name="DueMinuteComboBox"
                      Width="72"/>
            <TextBlock Text="分"
                       VerticalAlignment="Center"
                       Margin="6,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="5"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <Button Content="取消"
                    Width="80"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button Content="保存"
                    Width="80"
                    Height="30"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
