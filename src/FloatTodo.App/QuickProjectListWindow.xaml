<Window x:Class="FloatTodo.App.QuickProjectListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="项目列表"
        Width="520"
        Height="420"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="CanResize">
    <Grid Margin="10">
        <TextBlock x:Name="EmptyText"
                   Text="当前没有项目"
                   Visibility="Collapsed"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,8"/>

        <ListBox x:Name="ProjectsList"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10"
                            Margin="4"
                            Background="White"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding Project.Title}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Cursor="Hand"
                                           MouseLeftButtonUp="ProjectTitle_MouseLeftButtonUp"/>
                                <TextBlock Text="{Binding Project.Description}"
                                           Foreground="#666"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding DueTimeDisplay}"
                                           Foreground="#666"
                                           Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding ProgressDisplay}"
                                           Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding StatusDisplay}"
                                           Foreground="#666"
                                           Margin="0,3,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                <Button Content="查看小任务"
                                        Width="92"
                                        Margin="0,0,0,6"
                                        Tag="{Binding Project}"
                                        Click="ViewTasksButton_Click"/>
                                <Button Content="新增小任务"
                                        Width="92"
                                        Tag="{Binding Project}"
                                        Click="AddTaskButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
