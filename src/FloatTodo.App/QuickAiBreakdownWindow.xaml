<Window x:Class="FloatTodo.App.QuickAiBreakdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 项目拆解"
        Width="520"
        Height="560"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="CanResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="项目名称"
                       FontWeight="Bold"/>
            <TextBox x:Name="ProjectNameBox"
                     Margin="0,6,0,12"
                     Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="项目描述"
                       FontWeight="Bold"/>
            <TextBox x:Name="ProjectDescBox"
                     Margin="0,6,0,12"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Height="120"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left">
            <Button x:Name="GenerateButton"
                    Content="开始拆解"
                    Width="120"
                    Height="30"
                    Margin="0,0,8,8"
                    Click="GenerateButton_Click"/>
            <TextBlock x:Name="StatusText"
                       Text="正在拆解，请稍候..."
                       VerticalAlignment="Center"
                       Visibility="Collapsed"
                       Foreground="Gray"
                       Margin="8,0,0,8"/>
        </StackPanel>

        <ListBox x:Name="CandidatesList"
                 Grid.Row="3"
                 Margin="0,4,0,8"
                 ItemsSource="{Binding Candidates}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8"
                            Margin="4"
                            Background="#FFF"
                            CornerRadius="6"
                            BorderBrush="#EEE"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsSelected}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}"
                                           Foreground="#666"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0"/>
                                <TextBlock>
                                    <Run Text="优先级: "/>
                                    <Run Text="{Binding Priority}"/>
                                    <Run Text="  |  截止: "/>
                                    <Run Text="无截止时间"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <Button x:Name="AddSelectedButton"
                    Content="加入选中任务"
                    Width="120"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="AddSelectedButton_Click"/>
            <Button Content="取消"
                    Width="80"
                    Height="30"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
