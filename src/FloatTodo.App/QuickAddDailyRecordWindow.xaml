<Window x:Class="FloatTodo.App.QuickAddDailyRecordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增/修改记录项"
        Width="340"
        Height="250"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="记录项名称"
                   FontWeight="Bold"/>
        <TextBox x:Name="NameTextBox"
                 Grid.Row="1"
                 Margin="0,6,0,12"
                 Height="28"
                 VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="2"
                   Text="提醒阈值（分钟，可留空表示不提醒）"
                   FontWeight="Bold"/>
        <TextBox x:Name="ReminderThresholdTextBox"
                 Grid.Row="3"
                 Margin="0,6,0,6"
                 Height="28"
                 VerticalContentAlignment="Center"
                 ToolTip="请输入正整数；留空表示不启用提醒"/>
        <TextBlock Grid.Row="4"
                   Text="如果记录项已存在，将只修改提醒阈值，不会清空次数或最后记录时间。"
                   TextWrapping="Wrap"
                   Foreground="#666"
                   FontSize="12"/>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="取消"
                    Width="80"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button Content="保存"
                    Width="80"
                    Height="30"
                    Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
