<Window x:Class="FloatTodo.App.QuickTaskListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="未完成任务"
        Width="500"
        Height="400"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="CanResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="EmptyText"
                   Text="当前没有未完成任务。"
                   Visibility="Collapsed"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Margin="0,6"/>
        <ListBox x:Name="TasksList"
                 Grid.Row="1"
                 Visibility="Visible"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- 背景色用于区分紧急程度：浅红=逾期，浅橙=24小时内，浅蓝=未来截止，浅灰=无截止。 -->
                    <Border Padding="8"
                            Margin="4"
                            Background="{Binding Background, Mode=OneWay}"
                            CornerRadius="6"
                            BorderBrush="#EEE"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding Title, Mode=OneWay}"
                                           FontWeight="SemiBold"
                                           Cursor="Hand"
                                           MouseLeftButtonUp="TaskTitle_MouseLeftButtonUp"/>
                                <TextBlock Margin="0,3,0,0">
                                    <Run Text="优先级: "/>
                                    <Run Text="{Binding Priority, Mode=OneWay}"/>
                                    <Run Text="  |  截止: "/>
                                    <Run Text="{Binding DueTimeDisplay, Mode=OneWay}"/>
                                    <Run Text="  |  "/>
                                    <Run Text="{Binding UrgencyText, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding DescriptionPreview, Mode=OneWay}"
                                           Foreground="#666"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0">
                                <Button Content="完成"
                                        Width="56"
                                        Height="28"
                                        Margin="0,0,6,0"
                                        Tag="{Binding}"
                                        Click="CompleteButton_Click"/>
                                <Button Content="删除"
                                        Width="56"
                                        Height="28"
                                        Tag="{Binding}"
                                        Click="DeleteButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
