<Window x:Class="FloatTodo.App.QuickProjectTasksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="560"
        Height="440"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="CanResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ProjectDescriptionText"
                   TextWrapping="Wrap"
                   Foreground="#666"
                   Margin="4,0,4,8"/>

        <TextBlock x:Name="EmptyText"
                   Grid.Row="1"
                   Text="当前项目没有小任务"
                   Visibility="Collapsed"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,8"/>

        <ListBox x:Name="TasksList"
                 Grid.Row="1"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- 项目小任务也使用同一套紧急程度颜色规则，便于和普通任务列表保持一致。 -->
                    <Border Padding="10"
                            Margin="4"
                            Background="{Binding Background, Mode=OneWay}"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding Title, Mode=OneWay}"
                                           FontWeight="SemiBold"
                                           Cursor="Hand"
                                           MouseLeftButtonUp="TaskTitle_MouseLeftButtonUp"/>
                                <TextBlock Margin="0,4,0,0">
                                    <Run Text="优先级："/>
                                    <Run Text="{Binding Priority, Mode=OneWay}"/>
                                    <Run Text="  |  状态："/>
                                    <Run Text="{Binding StatusDisplay, Mode=OneWay}"/>
                                    <Run Text="  |  "/>
                                    <Run Text="{Binding UrgencyText, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding DueTimeDisplay, Mode=OneWay}"
                                           Foreground="#666"
                                           Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding DescriptionPreview, Mode=OneWay}"
                                           Foreground="#666"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0">
                                <Button Content="完成"
                                        Width="56"
                                        Height="28"
                                        Margin="0,0,6,0"
                                        Tag="{Binding}"
                                        Click="CompleteButton_Click"/>
                                <Button Content="删除"
                                        Width="56"
                                        Height="28"
                                        Tag="{Binding}"
                                        Click="DeleteButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
