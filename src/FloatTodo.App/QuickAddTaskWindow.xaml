<Window x:Class="FloatTodo.App.QuickAddTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增任务"
        Width="320"
        Height="430"
        MinHeight="410"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        WindowStyle="SingleBorderWindow"
        Background="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="任务标题"
                   FontWeight="Bold"/>
        <TextBox x:Name="TitleTextBox"
                 Grid.Row="1"
                 Margin="0,6,0,12"
                 Height="28"
                 VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="2"
                   Text="优先级"
                   FontWeight="Bold"/>
        <ComboBox x:Name="PriorityComboBox"
                  Grid.Row="3"
                  Margin="0,6,0,12"
                  Height="28"
                  SelectedIndex="0">
            <ComboBoxItem Content="普通"/>
            <ComboBoxItem Content="重要"/>
            <ComboBoxItem Content="紧急"/>
        </ComboBox>

        <TextBlock Grid.Row="4"
                   Text="截止日期"
                   FontWeight="Bold"/>
        <DatePicker x:Name="DueDatePicker"
                    Grid.Row="5"
                    Margin="0,6,0,12"
                    Height="28"/>

        <TextBlock Grid.Row="6"
                   Text="截止时间"
                   FontWeight="Bold"/>
        <TextBox x:Name="DueTimeTextBox"
                 Grid.Row="7"
                 Margin="0,6,0,4"
                 Height="28"
                 VerticalContentAlignment="Center"
                 ToolTip="HH:mm，可空；留空时默认为 23:59"/>
        <TextBlock Grid.Row="8"
                   Text="HH:mm，可空；选择日期后留空默认为 23:59"
                   FontSize="11"
                   Foreground="#666"
                   Margin="0,0,0,8"/>

        <StackPanel Grid.Row="9"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="取消"
                    Width="80"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button Content="添加"
                    Width="80"
                    Height="30"
                    Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
