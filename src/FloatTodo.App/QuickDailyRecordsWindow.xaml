<Window x:Class="FloatTodo.App.QuickDailyRecordsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="日常记录"
        Width="420"
        Height="360"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <TextBlock x:Name="EmptyText"
                   Text="当前没有日常记录"
                   Visibility="Collapsed"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,6"/>

        <ListBox x:Name="RecordsList"
                 Visibility="Visible">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8"
                            Margin="4"
                            Background="#FFF"
                            CornerRadius="6"
                            BorderBrush="#EEE"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#666">
                                    <Run Text="最后记录时间："/>
                                    <Run Text="{Binding LastRecordTimeDisplay}"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center">
                                <Run Text="次数："/>
                                <Run Text="{Binding TodayCount}"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
