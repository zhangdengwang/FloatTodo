<Window x:Class="FloatTodo.App.QuickDailyRecordsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理日常记录"
        Width="480"
        Height="380"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="CanResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="可查看记录状态，并修改提醒阈值。留空表示不启用提醒。"
                   TextWrapping="Wrap"
                   Foreground="#666"
                   Margin="4,0,4,8"/>

        <TextBlock x:Name="EmptyText"
                   Grid.Row="1"
                   Text="当前没有日常记录"
                   Visibility="Collapsed"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,6"/>

        <ListBox x:Name="RecordsList"
                 Grid.Row="1"
                 Visibility="Visible"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8"
                            Margin="4"
                            Background="#FFF"
                            CornerRadius="6"
                            BorderBrush="#EEE"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#666">
                                    <Run Text="次数："/>
                                    <Run Text="{Binding TodayCount}"/>
                                    <Run Text="  上次："/>
                                    <Run Text="{Binding LastRecordTimeDisplay}"/>
                                </TextBlock>
                            </StackPanel>

                            <TextBox Grid.Column="1"
                                     Text="{Binding ThresholdText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="28"
                                     Margin="8,0"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2"
                                    Content="保存阈值"
                                    Width="78"
                                    Height="28"
                                    Tag="{Binding}"
                                    Click="SaveThresholdButton_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
