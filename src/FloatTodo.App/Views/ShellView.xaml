<UserControl x:Class="FloatTodo.App.Views.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FloatTodo.App.ViewModels"
             MinHeight="520"
             MinWidth="360">
    <UserControl.DataContext>
        <vm:MainViewModel/>
    </UserControl.DataContext>

    <Border Background="#FFF8F8F8"
            CornerRadius="18"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="FloatTodo"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#2F2F2F"/>
                    <TextBlock Text="今日任务"
                               FontSize="14"
                               Foreground="#6F6F6F"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Margin="0,0,0,12"
                        Padding="12"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#F0F0F0"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="新增任务"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#2F2F2F"/>

                        <TextBox Margin="0,8,0,0"
                                 Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6"
                                 TextWrapping="Wrap"/>

                        <TextBox Margin="0,8,0,0"
                                 Height="60"
                                 Text="{Binding NewTaskDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"/>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                    Margin="0,0,8,0">
                                <TextBlock Text="优先级"
                                        FontSize="12"
                                        Foreground="#6F6F6F"/>
                                <ComboBox Margin="0,4,0,0"
                                          ItemsSource="{Binding Priorities}"
                                          SelectedItem="{Binding NewTaskPriority}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="截止时间"
                                        FontSize="12"
                                        Foreground="#6F6F6F"/>
                                <DatePicker Margin="0,4,0,0"
                                            SelectedDate="{Binding NewTaskDueTime}"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="添加任务"
                                Margin="0,12,0,0"
                                Padding="8"
                                Command="{Binding AddTaskCommand}"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="任务列表"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#2F2F2F"
                           Margin="0,0,0,8"/>

                <ItemsControl ItemsSource="{Binding Tasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="12"
                                    Background="White"
                                    CornerRadius="12"
                                    BorderBrush="#F0F0F0"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="#2F2F2F"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="#6F6F6F"
                                                   TextWrapping="Wrap"/>

                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Priority}"
                                                    FontSize="12"
                                                    Foreground="#7A4B00"
                                                    Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding Status}"
                                                    FontSize="12"
                                                    Foreground="#0F6C3B"/>
                                        </StackPanel>

                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding DueTime, StringFormat='截止: {0:yyyy/MM/dd HH:mm}', TargetNullValue='截止: 无'}"
                                                   FontSize="12"
                                                   Foreground="#6F6F6F"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                            Margin="10,0,0,0">
                                        <Button Content="完成"
                                                Margin="0,0,0,6"
                                                Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="删除"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
